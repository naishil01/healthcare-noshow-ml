# ════════════════════════════════════════════════════════════════
# MODEL 2 — Decision Tree with class_weight='balanced'
# Fix: one parameter added — model now treats no-shows as 4x
#      more important during training
# ════════════════════════════════════════════════════════════════
model_balanced = DecisionTreeClassifier(
    max_depth=5,
    random_state=42,
    class_weight='balanced'
)
model_balanced.fit(X_train, y_train)
y_pred_balanced = model_balanced.predict(X_test)

print("\nMODEL 2 — Decision Tree + class_weight='balanced'")
print(confusion_matrix(y_test, y_pred_balanced))
print(classification_report(y_test, y_pred_balanced))
print(f"ROC-AUC: {roc_auc_score(y_test, y_pred_balanced):.2f}")

# Output:
# [[11220  6401]
#  [ 1214  3271]]
#               precision  recall  f1-score  support
#            0       0.90    0.63      0.75    17715
#            1       0.34    0.73      0.46     4391
#     accuracy                         0.66    22106
#    macro avg       0.62    0.68      0.60    22106
# weighted avg       0.78    0.66      0.69    22106
# ROC-AUC: 0.68


# ════════════════════════════════════════════════════════════════
# MODEL 3 — Decision Tree with SMOTE oversampling
# Fix: synthetic no-show examples created so model trains
#      on a balanced 50/50 dataset
# ════════════════════════════════════════════════════════════════
smote = SMOTE(random_state=42)
X_train_sm, y_train_sm = smote.fit_resample(X_train, y_train)

print(f"\nTraining data before SMOTE : {len(X_train):,} rows")
print(f"Training data after  SMOTE : {len(X_train_sm):,} rows")

model_smote = DecisionTreeClassifier(max_depth=5, random_state=42)
model_smote.fit(X_train_sm, y_train_sm)
y_pred_smote = model_smote.predict(X_test)

print("\nMODEL 3 — Decision Tree + SMOTE")
print(confusion_matrix(y_test, y_pred_smote))
print(classification_report(y_test, y_pred_smote))
print(f"ROC-AUC: {roc_auc_score(y_test, y_pred_smote):.2f}")

# Output:
# Training data before SMOTE : 88,421 rows
# Training data after  SMOTE : 141,474 rows
